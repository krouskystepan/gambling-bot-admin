{
  "name": "gambling-bot-admin",
  "version": "2.0.0",
  "private": false,
  "scripts": {
    "prepare": "bash scripts/setup-git-hooks.sh",
    "predev": "bash ../gambling-bot-shared/scripts/ensure-linked.sh",
    "shared:link": "bash ../gambling-bot-shared/scripts/ensure-linked.sh",
    "shared:unlink": "bash ../gambling-bot-shared/scripts/unlink-app.sh",
    "shared:status": "bash ../gambling-bot-shared/scripts/shared-link-status.sh",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "type:check": "tsc --noEmit",
    "test:check": "vitest run",
    "test:coverage:check": "vitest run --coverage",
    "test:watch": "vitest",
    "check": "pnpm format:check && pnpm lint:check && pnpm type:check && pnpm test:coverage:check"
  },
  "dependencies": {
