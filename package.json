    "date-fns": "^4.4.0",
    "discord-api-types": "^0.38.48",
    "framer-motion": "^12.40.0",
    "gambling-bot-shared": "^1.0.13",
    "lucide-react": "^1.17.0",
    "luxon": "^3.7.2",
    "mongodb": "^7.3.0",
    "mongoose": "^9.7.0",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.78.0",
